{
  "name": "clinical-engineer-national-exam-quiz-app",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "build": "node -e \"console.log('No build needed. Cloudflare Pages output directory is project root: .');\"",
    "dev": "wrangler pages dev .",
    "deploy": "npm run deploy:pages",
    "deploy:pages": "wrangler pages deploy . --project-name clinical-engineer-national-exam-quiz --branch=main",
    "deploy:worker": "wrangler deploy --config wrangler.worker.toml",
    "deploy:worker:config": "wrangler deploy --config wrangler.worker.toml"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}